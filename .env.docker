GO_ENV=docker # prod / local / docker
# Конфигурация сервера
PORT=8080

# Конфигурация базы данных
DB_HOST=postgres
DB_PORT=5432
DB_NAME=subservice
DB_USER=postgres
DB_PASSWORD=postgres

# Конфигурация миграций БД
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=${GOOSE_DRIVER}://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable
GOOSE_MIGRATION_DIR=internal\infrastructure\database\migrations